# Build stage
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm install

# Copy source
COPY . .

# Expose Vite port
EXPOSE 1422

# Start development server
# Host 0.0.0.0 is required for Docker
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "1422"]
